            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company_to\": \"Buyer Company Ltd\",\n  \"purchase_type\": \"IMPORT\",\n  \"company_from\": \"Seller Company Ltd\",\n  \"product\": \"Sulphuric Acid\",\n  \"vessel_name\": \"MV Ocean Star\",\n  \"shipment\": \"FCL\",\n  \"quantity\": 500.0,\n  \"offer_usd\": 350.00,\n  \"exchange_rate\": 83.50,\n  \"price_inr\": 29225.00,\n  \"delivery_term\": \"CIF\",\n  \"payment_days\": 30,\n  \"port\": \"Mumbai Port\",\n  \"market_status\": \"FIRM\",\n  \"market_price\": 360.00,\n  \"cost_price\": 340.00,\n  \"replacement_cost\": 345.00,\n  \"price_fc\": 350.00,\n  \"make\": \"Industrial Grade\",\n  \"packaging\": \"Bulk\",\n  \"origin\": \"China\",\n  \"expense\": 5000.00,\n  \"custom_duty\": 7.50,\n  \"sws\": 10.00,\n  \"add\": 2.00,\n  \"other_expense\": 1500.00,\n  \"discharge_ports\": \"Mumbai, JNPT\",\n  \"price_type\": \"FIXED\",\n  \"payment_term\": \"LC 30 days\",\n  \"etd\": \"2026-07-01\",\n  \"eta\": \"2026-07-20\"\n}",
