{
  "info": {
    "name": "ChemOS API",
    "_postman_id": "chemos-api-collection-v1",
    "description": "ChemOS API Collection — Base URL: http://localhost:8081\n\nWorkflow:\n1. Run 'Login' first — the token is saved automatically to {{token}}.\n2. All other requests use {{token}} via the Authorization header.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token saved:', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Get a JWT token. No auth required.\n\nThe Tests script automatically saves the token to {{token}} for use in all subsequent requests."
          },
          "response": []
        },
        {
          "name": "Create User (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"password\": \"secret123\",\n  \"roleId\": \"admin\",\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "users"]
            },
            "description": "Create a new user. Requires ADMIN role.\n\nFields:\n- username: unique login name\n- password: min 6 characters\n- roleId: role identifier (e.g. \"admin\")\n- name: display name\n- email: valid email address"
          },
          "response": []
        },
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "users"]
            },
            "description": "List all users. Requires ADMIN role.\n\nReturns an array of UserResponse objects with id, username, isActive, role, and roleDisplay."
          },
          "response": []
        },
        {
          "name": "Toggle User Active (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/users/john_doe/toggle",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "users", "john_doe", "toggle"]
            },
            "description": "Toggle the active/inactive status of a user. Requires ADMIN role.\n\nReplace 'john_doe' in the URL with the target username."
          },
          "response": []
        }
      ]
    },
    {
